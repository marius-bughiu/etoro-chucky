# Copy this file to .env and fill in real values.
# .env is gitignored — never commit a real token.

# Your eToro agent-portfolio user token. Created via the agent-portfolio creation
# flow in SKILL.md and shown ONLY ONCE at creation time. Store it here.
ETORO_USER_TOKEN=

# Optional — UTC window during which the routine should be active.
# (Currently informational; the cron schedule itself is the source of truth.)
TRADING_WINDOW_START_UTC=06:30
TRADING_WINDOW_END_UTC=21:30
